rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── HELPER FUNCTIONS ────────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }
    function isAdmin() {
      return isAuth() && request.auth.token.email == 'tisa.helpdesk@gmail.com';
    }
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    function isWriter() {
      return isAuth() && (getUserRole() == 'writer' || getUserRole() == 'editor' || getUserRole() == 'admin' || isAdmin());
    }
    function isEditorOrAdmin() {
      return isAuth() && (getUserRole() == 'editor' || getUserRole() == 'admin' || isAdmin());
    }

    // ─── USERS ───────────────────────────────────────────────────
    match /users/{uid} {
      // Anyone authenticated can read any user profile
      allow read: if isAuth();
      // User can create their own profile on signup
      allow create: if isOwner(uid);
      // User can update their own profile; admin can update anyone's
      allow update: if isOwner(uid) || isAdmin();
      // Only admin can delete users
      allow delete: if isAdmin();
    }

    // ─── ARTICLES ────────────────────────────────────────────────
    match /articles/{articleId} {
      // Anyone can read published articles
      allow read: if resource.data.status == 'published';
      // Authenticated users can read pending articles they wrote
      allow read: if isAuth() && resource.data.authorId == request.auth.uid;
      // Admin/editors can read all articles
      allow read: if isEditorOrAdmin();

      // Writers can create new articles (status must be 'pending')
      allow create: if isWriter()
        && request.resource.data.status == 'pending'
        && request.resource.data.authorId == request.auth.uid;

      // Admin/editors can update any article (approve, reject, edit)
      allow update: if isEditorOrAdmin();
      // Authors can update their own PENDING articles
      allow update: if isAuth()
        && resource.data.authorId == request.auth.uid
        && resource.data.status == 'pending';
      // Any authenticated user can update likes/bookmarks fields only
      allow update: if isAuth()
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['likes', 'likedBy', 'bookmarkedBy', 'views']);

      // Only admin can delete
      allow delete: if isAdmin();

      // ─── COMMENTS ──────────────────────────────────────────────
      match /comments/{commentId} {
        // Anyone can read comments on published articles
        allow read: if true;
        // Authenticated users can create comments
        allow create: if isAuth()
          && request.resource.data.authorId == request.auth.uid;
        // Author of comment or admin can delete
        allow delete: if isAuth()
          && (resource.data.authorId == request.auth.uid || isAdmin());
        // No updates to comments
        allow update: if false;
      }
    }
  }
}
